beauty: a owl:Ontology ;
    rdfs:label "BeautyGraph Ontology" ;
    rdfs:comment "Ontologi untuk sistem pencarian produk skincare berbasis Semantic Web." .

beauty:P001 a beauty:Product ;
    rdfs:label "Niacinamide Serum 10%"^^xsd:string ;
    beauty:belongsToBrand beauty:Somethinc ;
    beauty:belongsToCategory beauty:Serum ;
    beauty:hasBenefit beauty:Brightening,
        beauty:PoreCare ;
    beauty:hasIngredient beauty:CentellaAsiatica,
        beauty:HyaluronicAcid,
        beauty:Niacinamide,
        beauty:VitaminC ;
    beauty:hasPriceRange beauty:Mid ;
    beauty:productName "Niacinamide Serum 10%"^^xsd:string ;
    beauty:sourceName "SOCO Review"^^xsd:string ;
    beauty:sourceURL "https://review.soco.id/product/face-serum/70514-niacinamide-moisture-beet-serum"^^xsd:anyURI ;
    beauty:suitableFor beauty:CombinationSkin,
        beauty:OilySkin,
        beauty:SensitiveSkin ;
    beauty:targetsConcern beauty:Acne,
        beauty:AcneMarks,
        beauty:LargePores .

